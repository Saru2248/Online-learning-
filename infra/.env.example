# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=eduflow_password
POSTGRES_DB=eduflow

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=redis_password

# ─── Meilisearch ──────────────────────────────────────────
MEILISEARCH_KEY=masterKey

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_USE_256_BIT_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── Services ─────────────────────────────────────────────
API_PORT=4000
WEB_PORT=3000
RECO_PORT=8000
